{
  "name": "medusa-plugin-nforce",
  "version": "0.1.0",
  "description": "Real-time product sync from Medusa to nForce knowledge bases.",
  "author": "nForce",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nforce-ai/medusa-plugin-nforce"
  },
  "homepage": "https://www.npmjs.com/package/medusa-plugin-nforce",
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "keywords": [
    "medusa",
    "plugin",
    "medusa-plugin",
    "medusa-plugin-other",
    "medusa-v2",
    "nforce",
    "knowledge-base",
    "ai"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "publish:local": "medusa plugin:publish"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "2.13.5",
    "@medusajs/cli": "2.13.5",
    "@medusajs/framework": "2.13.5",
    "@medusajs/icons": "2.13.5",
    "@medusajs/medusa": "2.13.5",
    "@medusajs/ui": "4.1.5",
    "@mikro-orm/migrations": "^6.4.3",
    "@swc/core": "^1.7.28",
    "@tanstack/react-query": "5.64.2",
    "cross-env": "^7.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "2.13.5",
    "@medusajs/cli": "2.13.5",
    "@medusajs/framework": "2.13.5",
    "@medusajs/icons": "2.13.5",
    "@medusajs/ui": "4.1.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "engines": {
    "node": ">=20"
  }
}
